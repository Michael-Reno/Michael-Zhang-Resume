---
// Self-hosted fonts (no Google Fonts CDN — privacy + performance).
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import '@fontsource/jetbrains-mono/800.css';
import '@fontsource/geist-sans/400.css';
import '@fontsource/geist-sans/500.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  jobTitle?: string;
  sameAs?: string[];
  ogImage?: string;
  personDescription?: string;
  alumniOf?: Array<{ name: string }>;
  knowsLanguage?: string[];
}
const {
  title,
  description,
  jobTitle = 'Senior Full Stack Drupal Developer',
  sameAs = [],
  ogImage = '/og.png',
  personDescription,
  alumniOf = [],
  knowsLanguage = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;

const personSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Michael Zhang',
  jobTitle,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Brisbane',
    addressRegion: 'QLD',
    addressCountry: 'AU',
  },
  url: canonical,
  sameAs,
};
if (personDescription) personSchema.description = personDescription;
if (alumniOf.length) personSchema.alumniOf = alumniOf.map((e) => ({ '@type': 'CollegeOrUniversity', name: e.name }));
if (knowsLanguage.length) personSchema.knowsLanguage = knowsLanguage;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_AU" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="theme-color" content="#04060E" />
    <meta name="generator" content={Astro.generator} />

    <!-- Decide the name "mask": gradient (default) vs plain white. Runs before
         paint to avoid a flash. Manual override wins; otherwise auto-detect. -->
    <script is:inline>
      (function () {
        var doc = document.documentElement;

        // 1. Manual override — deterministic per device. Visit ?mask=plain to
        //    force the plain white name (e.g. on a machine where the gradient
        //    renders wrong), ?mask=gradient to force it back. The choice is
        //    remembered in localStorage, so it sticks without the query string.
        var mode = null;
        try {
          var q = new URLSearchParams(location.search).get('mask');
          if (q === 'plain' || q === 'gradient') localStorage.setItem('maskMode', q);
          mode = localStorage.getItem('maskMode');
        } catch (e) { /* private mode etc. — fall through to auto-detect */ }

        if (mode === 'plain') { doc.classList.add('no-gradient-text'); return; }
        if (mode === 'gradient') { return; }

        // 2. Auto-detect known broken configs and fall back to plain white name.
        //    Two failure classes:
        //    a) Software/SwiftShader renderers — background-clip:text + WebGL canvas
        //       breaks regardless of GPU compositing path.
        //    b) Mac + Intel integrated GPU — Chrome's Metal compositor interacts badly
        //       with background-clip:text when a WebGL2 canvas is live on the page,
        //       even without CSS animations on h1. Plain white is more reliable there.
        var ok = true;
        try {
          if (
            !CSS.supports('(-webkit-background-clip:text)') &&
            !CSS.supports('(background-clip:text)')
          ) { ok = false; }
          if (ok) {
            var gl = document.createElement('canvas').getContext('webgl');
            if (gl) {
              var ext = gl.getExtension('WEBGL_debug_renderer_info');
              if (ext) {
                var r = gl.getParameter(ext.UNMASKED_RENDERER_WEBGL) || '';
                if (/swiftshader|software|llvmpipe|basic render|mesa offscreen/i.test(r)) ok = false;
                // Intel integrated GPU on Mac: Metal path has compositing issues
                // with background-clip:text when WebGL2 is active.
                if (ok && /\bIntel\b/i.test(r)) {
                  var ua = navigator.userAgent;
                  if (/Macintosh/i.test(ua) || /MacIntel/i.test(navigator.platform || '')) ok = false;
                }
              }
            }
          }
        } catch (e) { /* keep ok = true */ }
        if (!ok) doc.classList.add('no-gradient-text');
      })();
    </script>

    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body>
    <slot />

    <script>
      /* ---------------- scroll reveal ---------------- */
      (() => {
        const io = new IntersectionObserver(
          (es) => {
            es.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.25 }
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
