---
// GeodesicField — two-layer hero background, ported verbatim from
// design/hero-prototype.html. Do NOT simplify the shader or re-derive any
// constant; every value here was tuned and approved.
//
//   Layer 1 (#sky, offscreen Canvas 2D): the ion particle network.
//   Layer 2 (#gl, fullscreen WebGL2): a Schwarzschild photon-geodesic shader
//   that lenses Layer 1 as its sky texture.
//
// Black hole shader adapted from s0xDk/ghostty-blackhole (MIT), itself after
// Eric Bruneton's black hole shader. See README for full attribution.
---

<canvas id="sky" aria-hidden="true"></canvas>
<canvas id="gl" aria-hidden="true"></canvas>

<script>
  /* =====================================================================
     ION SKY + GEODESIC BLACK HOLE
     ---------------------------------------------------------------------
     Layer 1 (#sky, offscreen): the v1 ion particle network — drifting
     particles, neighbour links, cursor charge lines. Rendered every frame
     to a 2D canvas that becomes the "sky" texture.
     Layer 2 (#gl, fullscreen): a WebGL2 fragment shader that integrates
     Schwarzschild photon geodesics per pixel and LENSES the ion sky —
     particles bend, magnify and mirror around the event horizon.

     Black hole shader adapted from s0xDk/ghostty-blackhole (MIT),
     itself after Eric Bruneton's black hole shader. Pomodoro/token modes
     removed; fixed-size hole with gentle drift for a website hero.
     Keep this attribution if you reuse the shader.
     ===================================================================== */

  /* ------------------------- 1. the ion sky ------------------------- */
  const Sky = (() => {
    const canvas = document.getElementById('sky') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    // Background animation is intentionally ALWAYS on — we deliberately do NOT
    // honour prefers-reduced-motion here (owner's decision, 2026-06-30). This
    // overrides the CLAUDE.md "render one static frame under reduced-motion"
    // rule for the hero background only; the typed-role text (Hero.astro) and
    // CSS transitions (global.css) still respect the setting.
    const reduced = false;
    let w: number, h: number, particles: any[] = [];
    const mouse = { x: -9999, y: -9999 };
    const CYAN = [77, 227, 255], VIOLET = [157, 123, 255];

    function resize() {
      w = innerWidth; h = innerHeight;
      canvas.width = w; canvas.height = h;      // 1x — it's a texture, soft glows survive sampling
      const n = Math.min(110, Math.floor((w * h) / 16000));
      particles = Array.from({ length: n }, () => ({
        x: Math.random() * w, y: Math.random() * h,
        vx: (Math.random() - .5) * .35, vy: (Math.random() - .5) * .35,
        r: Math.random() * 1.6 + .6,
        c: Math.random() < .82 ? CYAN : VIOLET
      }));
    }

    const LINK = 130, MOUSE_LINK = 190;
    let lastMove = -1e9;                 // timestamp of last real pointer move
    function draw(animate: boolean) {
      ctx.fillStyle = '#04060E';
      ctx.fillRect(0, 0, w, h);

      /* mouse influence fades out ~1.5–2.5 s after the pointer stops:
         a parked cursor must not keep herding particles into a clump */
      const idle = performance.now() - lastMove;
      const mf = Math.max(0, Math.min(1, (2500 - idle) / 1000));

      if (animate) for (const p of particles) {
        // brownian wander: keeps motion irregular forever, prevents settling
        p.vx += (Math.random() - .5) * .016;
        p.vy += (Math.random() - .5) * .016;
        if (mf > 0) {
          const dx = mouse.x - p.x, dy = mouse.y - p.y;
          const md = Math.hypot(dx, dy);
          if (md < MOUSE_LINK && md > .001) {
            p.vx += dx / md * .012 * mf; p.vy += dy / md * .012 * mf;
          }
        }
        const sp = Math.hypot(p.vx, p.vy), MAX = .55;
        if (sp > MAX) { p.vx = p.vx / sp * MAX; p.vy = p.vy / sp * MAX; }
        p.x += p.vx; p.y += p.vy;
        if (p.x < -20) p.x = w + 20; if (p.x > w + 20) p.x = -20;
        if (p.y < -20) p.y = h + 20; if (p.y > h + 20) p.y = -20;
      }

      for (let i = 0; i < particles.length; i++) {
        const a = particles[i];
        for (let j = i + 1; j < particles.length; j++) {
          const b = particles[j];
          const d = Math.hypot(a.x - b.x, a.y - b.y);
          if (d < LINK) {
            ctx.strokeStyle = `rgba(${a.c[0]},${a.c[1]},${a.c[2]},${(1 - d / LINK) * .14})`;
            ctx.lineWidth = .7;
            ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
          }
        }
        if (mf > 0) {
          const dm = Math.hypot(a.x - mouse.x, a.y - mouse.y);
          if (dm < MOUSE_LINK) {
            ctx.strokeStyle = `rgba(77,227,255,${(1 - dm / MOUSE_LINK) * .35 * mf})`;
            ctx.lineWidth = .9;
            ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(mouse.x, mouse.y); ctx.stroke();
          }
        }
      }
      for (const p of particles) {
        ctx.fillStyle = `rgba(${p.c[0]},${p.c[1]},${p.c[2]},.78)`;
        ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2); ctx.fill();
      }
    }

    addEventListener('pointermove', e => {
      mouse.x = e.clientX; mouse.y = e.clientY;
      lastMove = performance.now();
    });
    addEventListener('pointerleave', () => { mouse.x = -9999; mouse.y = -9999; lastMove = -1e9; });

    return { canvas, resize, draw, reduced };
  })();

  /* ------------------ 2. the geodesic black hole ------------------ */
  const FRAG = `#version 300 es
  precision highp float;
  /* Adapted from s0xDk/ghostty-blackhole (MIT) — Schwarzschild geodesic
     integration in screen space; the ion-network canvas is the lensed sky. */
  uniform vec2  uRes;
  uniform float uTime;
  uniform vec2  uCenter;        // hole position, uv (y-up)
  uniform float uRh;            // shadow radius, fraction of screen height
  uniform sampler2D uSky;
  out vec4 outColor;

  /* blazar-style tuning (from the user's reference screenshot) */
  const float LENS_DEPTH    = 9.0;
  const float DISK_INNER    = 3.0;     // the ISCO — innermost stable orbit
  const float DISK_OUTER    = 16.0;    // wide, wispy disk
  const float DISK_INCL     = 1.05;
  const float DISK_ROLL     = 0.55;
  const float DISK_GAIN     = 1.0;
  const float DISK_OPACITY  = 0.3;     // translucent silver haze
  const float DISK_TEMP     = 18000.0; // blue-white blackbody
  const float DOPPLER_MIX   = 1.0;     // full relativistic asymmetry
  const float DISK_BEAM     = 5.0;
  const float DISK_SPEED    = 6.0;
  const float DISK_WIND     = 9.0;
  const float DISK_CONTRAST = 1.5;
  const float EXPOSURE      = 0.75;
  const float DILATION      = 0.2;     // ×DISK_SPEED → slow, stately motion
  #define N_STEPS 48
  #define B_CRIT 2.5980762

  float hash21(vec2 p){ p=fract(p*vec2(234.34,435.345)); p+=dot(p,p+34.23); return fract(p.x*p.y); }
  float vnoiseWrapY(vec2 p, float perY){
    vec2 i=floor(p), f=fract(p); f=f*f*(3.0-2.0*f);
    float y0=mod(i.y,perY), y1=mod(i.y+1.0,perY);
    return mix(mix(hash21(vec2(i.x,y0)),hash21(vec2(i.x+1.0,y0)),f.x),
               mix(hash21(vec2(i.x,y1)),hash21(vec2(i.x+1.0,y1)),f.x),f.y);
  }
  vec2 mirrorUV(vec2 u){ return 1.0-abs(1.0-mod(u,2.0)); }
  vec2 rot(vec2 v,float a){ float c=cos(a),s=sin(a); return vec2(c*v.x-s*v.y,s*v.x+c*v.y); }
  vec3 blackbody(float T){
    float t=clamp(T,1500.0,40000.0)/100.0;
    float r=t<=66.0?1.0:clamp(1.292936*pow(t-60.0,-0.1332047),0.0,1.0);
    float g=t<=66.0?clamp(0.3900816*log(t)-0.6318414,0.0,1.0)
                   :clamp(1.1298909*pow(t-60.0,-0.0755148),0.0,1.0);
    float b=t>=66.0?1.0:(t<=19.0?0.0:clamp(0.5432068*log(t-10.0)-1.1962540,0.0,1.0));
    return vec3(r,g,b);
  }

  void main(){
    vec2 res=uRes;
    vec2 uv=gl_FragCoord.xy/res;          // y-up (WebGL convention)
    float aspect=res.x/res.y;
    float t=uTime;
    float rin=DISK_INNER, rout=DISK_OUTER;
    float rh=uRh;

    vec2 p=(uv-uCenter)*vec2(aspect,1.0);
    float plen=length(p);
    float W=B_CRIT/max(rh,1e-4);
    vec2 pr=rot(p,DISK_ROLL)*W;
    float b=length(pr);

    float window=exp(-pow(plen/(7.0*rh),2.0));
    float bmax=rout+3.0;
    float Z0=max(14.0,rout+5.0);

    /* far field: analytic weak deflection + slight chromatic aberration */
    if(b>=bmax){
      float u=Z0*inversesqrt(Z0*Z0+b*b);
      float defl=(2.0/(W*W))/max(plen,1e-4)
               *(1.29*u+0.07)*max(LENS_DEPTH-2.14*u+0.75,0.0)*window;
      vec2 dir=p/max(plen,1e-5);
      vec3 term;
      float ab=0.035*smoothstep(1.0,2.0,b/bmax);
      for(int i=0;i<3;i++){
        float k=1.0+(float(i)-1.0)*ab;
        vec2 sp=p-dir*defl*k;
        vec2 suv=mirrorUV(uCenter+sp/vec2(aspect,1.0));
        term[i]=texture(uSky,suv)[i];
      }
      outColor=vec4(term,1.0);
      return;
    }

    /* near field: integrate the photon geodesic  x'' = -(3/2) h² x / r⁵ */
    vec3 x=vec3(pr,Z0);
    vec3 v=vec3(0.0,0.0,-1.0);
    float h2=dot(pr,pr);

    float ci=cos(DISK_INCL), si=sin(DISK_INCL);
    vec3 n=vec3(0.0,si,ci);
    vec3 e2=vec3(0.0,ci,-si);

    vec3 emitc=vec3(0.0);
    float trans=1.0;
    bool captured=false;
    float sPrev=dot(x,n);
    vec3 xPrev=x;

    for(int i=0;i<N_STEPS;i++){
      float r2=dot(x,x);
      if(r2<1.0){ captured=true; break; }
      if(x.z<-Z0&&v.z<0.0) break;
      if(r2>4.0*Z0*Z0) break;
      float r=sqrt(r2);
      float dt=clamp(0.16*r,0.03,1.5);
      vec3 a=-1.5*h2*x/(r2*r2*r);
      v+=a*(0.5*dt);
      x+=v*dt;
      r2=dot(x,x); r=sqrt(r2);
      a=-1.5*h2*x/(r2*r2*r);
      v+=a*(0.5*dt);

      float s=dot(x,n);
      if(s*sPrev<0.0&&trans>0.02){
        float tc=sPrev/(sPrev-s);
        vec3 xc=mix(xPrev,x,tc);
        float rc=length(xc);
        if(rc>rin&&rc<rout){
          float band=smoothstep(rin,rin*1.25,rc)*(1.0-smoothstep(rout*0.70,rout,rc));
          float phi=atan(dot(xc,e2),xc.x);
          float turns=phi/6.2831853;
          float kep=pow(rin/rc,1.5);
          float gloc=sqrt(max(1.0-1.5/rc,0.02));
          float swirl=rc*DISK_WIND*0.12-t*kep*DISK_SPEED*gloc*DILATION;
          float streaks=vnoiseWrapY(vec2(rc*2.8,turns*19.0+swirl*3.0),19.0)*0.65
                       +vnoiseWrapY(vec2(rc*1.0,turns*9.0+swirl*1.5+7.0),9.0)*0.35;
          streaks=0.35+DISK_CONTRAST*streaks*streaks;

          vec3 gasdir=normalize(cross(n,xc));
          float beta=clamp(inversesqrt(max(2.0*(rc-1.0),0.2)),0.0,0.99);
          float g=gloc/max(1.0+beta*dot(gasdir,normalize(v)),0.05);
          g=mix(1.0,g,DOPPLER_MIX);

          float xpr=max(1.0-sqrt(rin/rc),0.0);
          float tprof=pow(rin/rc,0.75)*pow(xpr,0.25)/0.488;
          vec3 cbb=blackbody(DISK_TEMP*tprof*g);
          float boost=pow(g,DISK_BEAM);

          float density=band*streaks;
          emitc+=trans*cbb*(DISK_GAIN*2.2*density*tprof*tprof*boost);
          trans*=1.0-clamp(DISK_OPACITY*density,0.0,1.0);
        }
      }
      sPrev=s; xPrev=x;
    }
    if(!captured&&dot(x,x)<4.0) captured=true;

    vec3 bg=vec3(0.0);
    if(!captured){
      vec3 d=normalize(v);
      if(d.z<-0.05){
        float tpl=(-LENS_DEPTH-x.z)/d.z;
        vec3 hp=x+d*tpl;
        vec2 q=rot(hp.xy,-DISK_ROLL)/W;
        vec2 suv=mirrorUV(uCenter+(p+(q-p)*window)/vec2(aspect,1.0));
        float toward=smoothstep(0.05,0.35,-d.z);
        bg+=texture(uSky,suv).rgb*toward;
      }
    }
    vec3 col=bg*trans+(vec3(1.0)-exp(-emitc*EXPOSURE));
    outColor=vec4(col,1.0);
  }`;

  const VERT = `#version 300 es
  void main(){
    vec2 v=vec2((gl_VertexID<<1)&2, gl_VertexID&2);
    gl_Position=vec4(v*2.0-1.0,0.0,1.0);
  }`;

  (() => {
    const glCanvas = document.getElementById('gl') as HTMLCanvasElement;
    const reduced = Sky.reduced;

    /* Fallback: no WebGL2, OR any WebGL/shader failure on quirky GPUs/drivers
       (compile/link error, context loss) → show the animated ion sky alone
       instead of a blank background. Compatibility hardening: never leave the
       hero empty just because the geodesic shader couldn't start. */
    function ionSkyFallback() {
      Sky.canvas.style.display = 'block';
      Sky.resize();
      if (reduced) { Sky.draw(false); return; }
      (function loop() { Sky.draw(true); requestAnimationFrame(loop); })();
    }

    const gl = glCanvas.getContext('webgl2', { antialias: false });
    if (!gl) { ionSkyFallback(); return; }

    try {

    function compile(type: number, src: string) {
      const s = gl!.createShader(type)!;
      gl!.shaderSource(s, src); gl!.compileShader(s);
      if (!gl!.getShaderParameter(s, gl!.COMPILE_STATUS))
        throw new Error(gl!.getShaderInfoLog(s) || 'shader compile failed');
      return s;
    }
    const prog = gl.createProgram()!;
    gl.attachShader(prog, compile(gl.VERTEX_SHADER, VERT));
    gl.attachShader(prog, compile(gl.FRAGMENT_SHADER, FRAG));
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS))
      throw new Error(gl.getProgramInfoLog(prog) || 'program link failed');
    gl.useProgram(prog);

    const uRes = gl.getUniformLocation(prog, 'uRes');
    const uTime = gl.getUniformLocation(prog, 'uTime');
    const uCenter = gl.getUniformLocation(prog, 'uCenter');
    const uRh = gl.getUniformLocation(prog, 'uRh');

    const tex = gl.createTexture();
    gl.bindTexture(gl.TEXTURE_2D, tex);
    gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL, true);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
    gl.uniform1i(gl.getUniformLocation(prog, 'uSky'), 0);

    let w: number, h: number, dpr: number, texW = 0, texH = 0;
    /* roam box: the WHOLE hole wanders the right side of the screen (y-up uv).
       mid = box centre, amp = half-extent per axis. With DRIFT=.26 the
       dominant x period is ~65 s and y ~45 s — clearly drifting, never rushed,
       and the incommensurate frequencies keep the path irregular. */
    const roam = { midX: .74, midY: .60, ampX: .14, ampY: .24 };
    const DRIFT = .26;
    const par = { x: 0, y: 0, tx: 0, ty: 0 };
    let raf: number;

    /* unit Lissajous wander (from ghostty-blackhole): 2+2 incommensurate
       sines per axis — the path never visibly repeats, so the motion reads
       as irregular without any randomness state */
    function lissa(t: number) {
      return [
        .75 * Math.sin(t * .37) + .25 * Math.sin(t * .83 + 1.0),
        .70 * Math.sin(t * .54 + 2.1) + .30 * Math.sin(t * 1.07)
      ];
    }

    function resize() {
      dpr = Math.min(devicePixelRatio || 1, 1.5);   // geodesics are expensive — cap dpr
      w = innerWidth; h = innerHeight;
      glCanvas.width = w * dpr; glCanvas.height = h * dpr;
      gl!.viewport(0, 0, glCanvas.width, glCanvas.height);
      Sky.resize();
      const mobile = w < 760;
      if (mobile) {           // narrow screens: upper-right, smaller box
        roam.midX = .76; roam.midY = .76; roam.ampX = .10; roam.ampY = .14;
      } else {
        roam.midX = .74; roam.midY = .60; roam.ampX = .14; roam.ampY = .24;
      }
      holeR = mobile ? .030 : .026;   // wispy blazar disk spans ~1/3 viewport height
    }
    let holeR = .026;

    function uploadSky() {
      gl!.bindTexture(gl!.TEXTURE_2D, tex);
      if (Sky.canvas.width !== texW || Sky.canvas.height !== texH) {
        texW = Sky.canvas.width; texH = Sky.canvas.height;
        gl!.texImage2D(gl!.TEXTURE_2D, 0, gl!.RGBA, gl!.RGBA, gl!.UNSIGNED_BYTE, Sky.canvas);
      } else {
        gl!.texSubImage2D(gl!.TEXTURE_2D, 0, 0, 0, gl!.RGBA, gl!.UNSIGNED_BYTE, Sky.canvas);
      }
    }

    function render(timeSec: number) {
      par.x += (par.tx - par.x) * .04;
      par.y += (par.ty - par.y) * .04;
      const [lx, ly] = lissa(timeSec * DRIFT);
      const cx = roam.midX + lx * roam.ampX + par.x;
      const cy = roam.midY + ly * roam.ampY + par.y;
      gl!.uniform2f(uRes, glCanvas.width, glCanvas.height);
      gl!.uniform1f(uTime, timeSec);
      gl!.uniform2f(uCenter, cx, cy);
      gl!.uniform1f(uRh, holeR);
      gl!.drawArrays(gl!.TRIANGLES, 0, 3);
    }

    function frame(now: number) {
      Sky.draw(true);
      uploadSky();
      render(now / 1000);
      raf = requestAnimationFrame(frame);
    }

    addEventListener('resize', () => {
      resize();
      if (reduced) { Sky.draw(false); uploadSky(); render(0); }
    });
    addEventListener('pointermove', e => {
      par.tx = (e.clientX / w - .5) * -.022;
      par.ty = (e.clientY / h - .5) * .016;   // y-up: invert
    });
    document.addEventListener('visibilitychange', () => {
      if (reduced) return;
      if (document.hidden) cancelAnimationFrame(raf);
      else raf = requestAnimationFrame(frame);
    });

    resize();
    if (reduced) { Sky.draw(false); uploadSky(); render(0); }
    else raf = requestAnimationFrame(frame);

    } catch (err) {
      console.warn('[GeodesicField] WebGL2 black hole unavailable, falling back to ion sky:', err);
      ionSkyFallback();
    }
  })();
</script>
